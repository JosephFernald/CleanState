{
  "metadata": [
    {
      "src": [
        {
          "files": [ "src/CleanState/CleanState.csproj" ],
          "src": "../"
        }
      ],
      "dest": "api",
      "includePrivateMembers": false,
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "properties": {
        "TargetFramework": "netstandard2.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "api/**.yml", "api/index.md" ]
      },
      {
        "files": [ "articles/**.md", "articles/**/toc.yml", "toc.yml", "*.md" ]
      },
      {
        "files": [ "samples/**.md", "samples/**/toc.yml" ]
      }
    ],
    "resource": [
      {
        "files": [ "images/**" ]
      }
    ],
    "output": "_site",
    "template": [ "default", "modern", "templates/material/material" ],
    "globalMetadata": {
      "_appTitle": "CleanState",
      "_appName": "CleanState",
      "_appFooter": "CleanState - Deterministic FSM Framework",
      "_enableSearch": true,
      "_appLogoPath": "images/CleanStateIcon.svg",
      "_appFaviconPath": "images/CleanStateIcon.svg"
    }
  }
}
